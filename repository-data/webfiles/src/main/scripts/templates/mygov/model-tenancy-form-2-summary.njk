                    <span class="ds_summary-list__value"><q class="ds_summary-list__answer">{{lettingAgent.email}}</q></span>
                    <div class="ds_summary-list__actions">
                        <button class="ds_link  js-change" data-slug="{{itemSlug}}" aria-describedby="{{itemSlug}}-email">Change</button>
                    </div>
                </li>
