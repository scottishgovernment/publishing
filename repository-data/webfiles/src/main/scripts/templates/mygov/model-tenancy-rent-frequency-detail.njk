{% from "../macros.njk" import pageTitle %}

<div class="form-container__title">{{ pageTitle(title, sectionTitle) }}</div>

{% macro daySelectQuestion(id='tenancy-payment-frequency-day', labelText='On which day?', placeholderText='Choose a day') %}
    <div class="ds_question">
        <label class="ds_label" for="{{id}}">{{labelText}}</label>
        <div class="ds_select-wrapper">
            <select class="ds_select" id="{{id}}">
                <option value="" disabled="" selected="">{{placeholderText}}</option>
                <option>Monday</option>
                <option>Tuesday</option>
                <option>Wednesday</option>
                <option>Thursday</option>
                <option>Friday</option>
                <option>Saturday</option>
                <option>Sunday</option>
            </select>
            <span class="ds_select-arrow" aria-hidden="true"></span>
        </div>
    </div>
{% endmacro %}

{% macro weekSelectQuestion(id='tenancy-payment-frequency-week', labelText='On which week?', placeholderText='Choose a week', fourWeeks=true) %}
    <div class="ds_question">
        <label class="ds_label" for="{{id}}">{{labelText}}</label>
        <div class="ds_select-wrapper">
            <select class="ds_select" id="{{id}}">
                <option value="" disabled="" selected="">{{placeholderText}}</option>
                <option>First week</option>
                <option>Second week</option>
                {% if fourWeeks %}
                    <option>Third week</option>
                    <option>Fourth week</option>
                {% endif %}
            </select>
            <span class="ds_select-arrow" aria-hidden="true"></span>
        </div>
    </div>
{% endmacro %}

{% macro monthSelectQuestion(id='tenancy-payment-frequency-date', labelText='On what day?', placeholderText='Choose a day')  %}
    <div class="ds_question">
        <label class="ds_label" for="{{id}}">{{labelText}}</label>
        <div class="ds_select-wrapper">
            <select class="ds_select" id="{{id}}">
                <option value="" disabled="" selected="">{{placeholderText}}</option>
                <option>last day</option>
                <option>last Friday</option>
                <option>1st</option><option>2nd</option><option>3rd</option><option>4th</option>
                <option>5th</option><option>6th</option><option>7th</option><option>8th</option>
                <option>9th</option><option>10th</option><option>11th</option><option>12th</option>
                <option>13th</option><option>14th</option><option>15th</option><option>16th</option>
                <option>17th</option><option>18th</option><option>19th</option><option>20th</option>
                <option>21st</option><option>22nd</option><option>23rd</option><option>24th</option>
                <option>25th</option><option>26th</option><option>27th</option><option>28th</option>
            </select>
            <span class="ds_select-arrow" aria-hidden="true"></span>
        </div>
    </div>
{% endmacro %}

{% if frequency === 'WEEKLY' %}
    {{ daySelectQuestion() }}
{% elif frequency === 'FORTNIGHTLY' %}
    {{ weekSelectQuestion(fourWeeks=false) }}
    {{ daySelectQuestion() }}
{% elif frequency === 'EVERY_FOUR_WEEKS' %}
    {{ weekSelectQuestion() }}
    {{ daySelectQuestion() }}
{% elif frequency === 'CALENDAR_MONTH' %}
    {{ monthSelectQuestion(labelText='On which day of the month?') }}
{% elif frequency === 'QUARTERLY' %}
    {{ monthSelectQuestion(labelText='On which day of the quarter?') }}
{% elif frequency === 'EVERY_SIX_MONTHS' %}
    {{ monthSelectQuestion(labelText='On which day of the 6-month period?') }}
{% endif %}
